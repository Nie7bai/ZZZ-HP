DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=zzz
PORT=3010

# 腾讯云 OCR（GeneralAccurateOCR）— 密钥只放服务端，勿提交 Git
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_OCR_REGION=ap-guangzhou

# 云识别每月上限；OCR_MONTH_USED_SEED 仅首次创建计数文件时生效（默认 4 → 剩余 996）
OCR_MONTHLY_LIMIT=1000
OCR_MONTH_USED_SEED=4
# 普通用户每人每月云识别次数；管理员不受此限，但仍受 OCR_MONTHLY_LIMIT 约束
# 站点管理员米游社 AID（逗号分隔），用于接收用户举报/解封申请通知；也可在账号管理中勾选「站点管理员」
SITE_ADMIN_MIHOYO_AIDS=
